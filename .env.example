# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional base path for GitHub Pages (e.g. /typewise)
NEXT_PUBLIC_BASE_PATH=

# When site is on GitHub Pages, point submit form to your API host (Vercel, etc.)
# Example: https://typewise-api.vercel.app
NEXT_PUBLIC_SUBMIT_API_URL=

# PostgreSQL (Neon recommended) — optional in dev; submissions stored when set
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Gmail / SMTP (App Password: https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="Typewise <noreply@your-domain.com>"
MAIL_TO=admin@your-domain.com

# Cloudflare Turnstile — https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# Google AdSense — https://www.google.com/adsense/
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Optional: Upstash Redis for shared rate limiting on serverless
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin key for reviewing submissions via API (optional)
ADMIN_API_KEY=replace_with_secure_random_key
